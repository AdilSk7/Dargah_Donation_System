# Copy this file to .env and fill in your values

# MySQL connection string
# Format: mysql+pymysql://USERNAME:PASSWORD@HOST/DATABASE_NAME
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost/dargah_db

# JWT Secret - change this to any long random string
JWT_SECRET=dargah-super-secret-key-change-this-in-production

# Optional: Razorpay (for automatic payment verification)
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# Optional: MSG91 (for SMS reminders)
# MSG91_AUTH_KEY=your_msg91_key
# MSG91_FLOW_ID=your_flow_id
